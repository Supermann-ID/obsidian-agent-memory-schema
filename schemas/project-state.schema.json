{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Supermann-ID/obsidian-agent-memory-schema/schemas/project-state.schema.json",
  "title": "Agent Project State",
  "type": "object",
  "required": ["name", "status", "updated", "summary"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["idea", "active", "blocked", "paused", "done", "archived"]
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string"
    },
    "currentFocus": {
      "type": "string"
    },
    "nextActions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "url"],
        "additionalProperties": false,
        "properties": {
          "label": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      }
    }
  }
}
